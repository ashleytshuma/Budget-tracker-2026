  let b=amount,schedule=[],startDate=new Date();startDate.setDate(1);startDate.setMonth(startDate.getMonth()+1);
  for(let i=0;i<240&&b>0.01;i++){const pmt=Math.min(pay,b);b=Math.max(0,b-pmt);schedule.push({date:new Date(startDate.getFullYear(),startDate.getMonth()+i,1).toISOString().split('T')[0],payment:pmt,balance:b,paid:false});}
  c.plan={monthlyPayment:pay,totalPayments:schedule.reduce((s,p)=>s+p.payment,0),payoffDate:schedule[schedule.length-1]?.date||'',schedule};
  save();renderCollections();
}

