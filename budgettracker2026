function calcPaymentPlan(loanId){
  const loan=findLoan(loanId);if(!loan)return;
  const bal=Number(loan.balance||0),rate=Number(loan.interestRate||0)/100/12,minPay=Number(loan.minPayment||0);
  const extra=Number(document.getElementById('plan-extra-'+loanId)?.value||0);
  let monthsTarget=parseInt(document.getElementById('plan-months-'+loanId)?.value||0);
  let monthlyPayment=minPay+extra;
  if(monthsTarget>0&&bal>0){monthlyPayment=rate>0?bal*rate*Math.pow(1+rate,monthsTarget)/(Math.pow(1+rate,monthsTarget)-1):bal/monthsTarget;monthlyPayment=Math.max(monthlyPayment,minPay);}
  if(monthlyPayment<=0)return alert('Enter an extra payment or target months');
  let b=bal,totalInt=0,schedule=[],startDate=new Date();startDate.setDate(1);startDate.setMonth(startDate.getMonth()+1);
  for(let i=0;i<240&&b>0.01;i++){const int=b*rate,pmt=Math.min(monthlyPayment,b+int),principal=pmt-int;totalInt+=int;b=Math.max(0,b-principal);schedule.push({date:new Date(startDate.getFullYear(),startDate.getMonth()+i,1).toISOString().split('T')[0],payment:pmt,principal,interest:int,balance:b,paid:false});}
  loan.plan={monthlyPayment,totalInterest:totalInt,payoffDate:schedule[schedule.length-1]?.date||'',schedule};
  saveLoanObj(loanId,loan);renderLoans();
}

function clearPlan(loanId){const loan=findLoan(loanId);if(!loan)return;delete loan.plan;saveLoanObj(loanId,loan);renderLoans();}
function togglePlanPaid(loanId,idx){const loan=findLoan(loanId);if(!loan||!loan.plan)return;loan.plan.schedule[idx].paid=!loan.plan.schedule[idx].paid;saveLoanObj(loanId,loan);renderLoans();}

