<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Budget & Bill Tracker</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#f5f3ff;--card:#ffffff;--sidebar:#ede9fe;
  --purple:#c4b5fd;--purple-d:#a78bfa;--purple-l:#f3e8ff;
  --blue:#bae6fd;--blue-l:#e0f2fe;
  --pink:#fca5a5;--pink-l:#ffe4e6;
  --green:#86efac;--green-l:#dcfce7;
  --peach:#fdba74;--peach-l:#ffedd5;
  --yellow:#fde68a;--yellow-l:#fefce8;
  --mint:#99f6e4;--mint-l:#ccfbf1;
  --text:#3d3466;--text-mid:#6b6494;--text-light:#9ca3af;
  --border:#ede9fe;--shadow:0 2px 16px rgba(139,92,246,.09);--radius:14px;
}
body{font-family:'Segoe UI',system-ui,sans-serif;background:var(--bg);color:var(--text);min-height:100vh;display:flex}
/* SIDEBAR */
.sidebar{width:220px;min-height:100vh;background:var(--sidebar);display:flex;flex-direction:column;padding:24px 12px;position:fixed;top:0;left:0;bottom:0;border-right:1.5px solid var(--border);overflow-y:auto}
.sidebar-logo{font-size:1.1rem;font-weight:700;color:var(--text);padding:0 8px 20px;display:flex;align-items:center;gap:8px}
.sidebar-logo span{font-size:1.4rem}
.nav-item{display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:10px;cursor:pointer;font-size:.85rem;font-weight:500;color:var(--text-mid);transition:.15s;margin-bottom:2px;user-select:none}
.nav-item:hover{background:rgba(167,139,250,.15);color:var(--text)}
.nav-item.active{background:var(--purple);color:var(--text);font-weight:600;box-shadow:0 2px 8px rgba(167,139,250,.3)}
.nav-icon{font-size:1rem;width:20px;text-align:center}
.sidebar-bottom{margin-top:auto;padding:16px 8px 8px;border-top:1px solid var(--border)}
.net-label{font-size:.7rem;color:var(--text-light);text-transform:uppercase;letter-spacing:.06em;margin-bottom:4px}
.net-amount{font-size:1.4rem;font-weight:700}
.net-amount.positive{color:#059669}.net-amount.negative{color:#dc2626}
/* MAIN */
.main{margin-left:220px;flex:1;padding:28px 28px 60px;min-height:100vh}
.page{display:none}.page.active{display:block}
.page-header{margin-bottom:22px}
.page-title{font-size:1.45rem;font-weight:700;margin-bottom:4px}
.page-sub{font-size:.875rem;color:var(--text-light)}
/* GRID */
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:20px}
.grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;margin-bottom:20px}
.grid4{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:16px;margin-bottom:20px}
/* CARD */
.card{background:var(--card);border-radius:var(--radius);padding:20px;box-shadow:var(--shadow);border:1.5px solid var(--border)}
.card-title{font-size:.78rem;font-weight:600;color:var(--text-light);text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px}
.card-value{font-size:1.55rem;font-weight:700}
.card-sub{font-size:.78rem;color:var(--text-light);margin-top:4px}
.card-accent{border-left:4px solid var(--purple)}.card-green{border-left:4px solid var(--green)}
.card-pink{border-left:4px solid var(--pink)}.card-peach{border-left:4px solid var(--peach)}
.card-blue{border-left:4px solid var(--blue)}.card-yellow{border-left:4px solid var(--yellow)}
.card-mint{border-left:4px solid var(--mint)}
.section-title{font-size:.95rem;font-weight:700;margin-bottom:14px;display:flex;align-items:center;justify-content:space-between}
/* CHART */
.chart-wrap{position:relative;height:220px}.chart-wrap-sm{position:relative;height:180px}
/* BUTTONS */
.btn{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border-radius:8px;border:none;cursor:pointer;font-size:.85rem;font-weight:600;transition:.15s}
.btn-primary{background:var(--purple);color:var(--text)}.btn-primary:hover{background:var(--purple-d);color:#fff}
.btn-sm{padding:5px 11px;font-size:.77rem;border-radius:7px}
.btn-ghost{background:transparent;color:var(--text-mid);border:1.5px solid var(--border)}.btn-ghost:hover{background:var(--purple-l)}
.btn-danger{background:var(--pink-l);color:#be123c;border:1.5px solid var(--pink)}.btn-danger:hover{background:var(--pink);color:#fff}
.btn-green{background:var(--green-l);color:#065f46;border:1.5px solid var(--green)}.btn-green:hover{background:var(--green)}
.btn-blue{background:var(--blue-l);color:#0369a1;border:1.5px solid var(--blue)}.btn-blue:hover{background:var(--blue)}
/* TABS */
.tabs{display:flex;gap:6px;margin-bottom:18px;flex-wrap:wrap}
.tab{padding:7px 15px;border-radius:8px;cursor:pointer;font-size:.82rem;font-weight:600;color:var(--text-mid);background:var(--card);border:1.5px solid var(--border);transition:.15s}
.tab:hover{background:var(--purple-l)}.tab.active{background:var(--purple);color:var(--text);border-color:var(--purple)}
/* PROGRESS */
.progress-outer{background:#f1eeff;border-radius:99px;height:10px;overflow:hidden}
.progress-inner{height:100%;border-radius:99px;transition:width .5s}
/* BADGE */
.badge{display:inline-block;padding:2px 10px;border-radius:99px;font-size:.7rem;font-weight:700}
.badge-green{background:var(--green-l);color:#065f46}.badge-pink{background:var(--pink-l);color:#be123c}
.badge-peach{background:var(--peach-l);color:#92400e}.badge-purple{background:var(--purple-l);color:#6d28d9}
.badge-blue{background:var(--blue-l);color:#0369a1}.badge-yellow{background:var(--yellow-l);color:#92400e}
.badge-mint{background:var(--mint-l);color:#065f46}
/* ITEM ROW */
.item-row{display:flex;align-items:center;gap:12px;padding:11px 0;border-bottom:1px solid var(--border)}
.item-row:last-child{border-bottom:none}
.item-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
.item-name{flex:1;font-size:.875rem;font-weight:500}
.item-amount{font-size:.875rem;font-weight:700}
.item-meta{font-size:.75rem;color:var(--text-light)}
/* FORM */
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px}
.form-row-1{margin-bottom:12px}
.form-group{display:flex;flex-direction:column;gap:5px}
label{font-size:.78rem;font-weight:600;color:var(--text-mid)}
input,select,textarea{padding:9px 12px;border:1.5px solid var(--border);border-radius:8px;font-size:.875rem;color:var(--text);background:#fafaf9;outline:none;transition:.15s;font-family:inherit}
input:focus,select:focus,textarea:focus{border-color:var(--purple-d);background:#fff;box-shadow:0 0 0 3px rgba(196,181,253,.2)}
textarea{resize:vertical;min-height:70px}
/* MODAL */
.modal-overlay{position:fixed;inset:0;background:rgba(61,52,102,.35);z-index:999;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:.2s}
.modal-overlay.open{opacity:1;pointer-events:all}
.modal{background:var(--card);border-radius:18px;padding:28px;width:500px;max-width:95vw;max-height:90vh;overflow-y:auto;box-shadow:0 8px 40px rgba(61,52,102,.18);transform:translateY(10px);transition:.2s}
.modal-overlay.open .modal{transform:translateY(0)}
.modal-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px}
.modal-title{font-size:1.05rem;font-weight:700}
.modal-close{background:none;border:none;cursor:pointer;font-size:1.2rem;color:var(--text-light);padding:4px;border-radius:6px}
.modal-close:hover{background:var(--purple-l)}
.modal-footer{display:flex;gap:10px;justify-content:flex-end;margin-top:18px;padding-top:16px;border-top:1px solid var(--border)}
/* LOAN CARD */
.loan-card{background:var(--card);border:1.5px solid var(--border);border-radius:var(--radius);padding:18px;box-shadow:var(--shadow);margin-bottom:14px}
.loan-header{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:14px}
.loan-name{font-size:.95rem;font-weight:700}
.loan-lender{font-size:.75rem;color:var(--text-light)}
.loan-actions{display:flex;gap:6px;flex-wrap:wrap}
.loan-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:12px}
.loan-stat-label{font-size:.68rem;text-transform:uppercase;letter-spacing:.06em;color:var(--text-light);margin-bottom:3px}
.loan-stat-value{font-size:.95rem;font-weight:700}
.loan-plan{background:var(--purple-l);border-radius:10px;padding:14px;margin-top:12px}
.loan-plan-title{font-size:.78rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:var(--purple-d);margin-bottom:10px}
.plan-schedule{max-height:180px;overflow-y:auto;margin-top:8px}
.plan-row{display:flex;justify-content:space-between;font-size:.74rem;padding:4px 0;border-bottom:1px solid rgba(196,181,253,.3);gap:6px}
.plan-row:last-child{border-bottom:none}.plan-row.paid{color:var(--text-light);text-decoration:line-through}
/* DOCS mini-section */
.docs-mini{background:#faf8ff;border-radius:10px;padding:12px;margin-top:12px;border:1.5px dashed var(--border)}
.docs-mini-title{font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:var(--text-light);margin-bottom:8px;display:flex;align-items:center;justify-content:space-between}
.doc-mini-item{display:flex;align-items:center;gap:8px;padding:5px 0;border-bottom:1px solid var(--border);font-size:.78rem}
.doc-mini-item:last-child{border-bottom:none}
.doc-mini-name{flex:1;font-weight:500}
/* GOAL CARD */
.goal-card{background:var(--card);border:1.5px solid var(--border);border-radius:var(--radius);padding:18px;box-shadow:var(--shadow);margin-bottom:14px}
/* TOGGLE */
.toggle-wrap{display:flex;align-items:center;gap:8px;cursor:pointer;user-select:none}
.toggle{width:38px;height:20px;border-radius:99px;position:relative;transition:.2s;flex-shrink:0}
.toggle.on{background:var(--green)}.toggle.off{background:#d1d5db}
.toggle::after{content:'';position:absolute;width:16px;height:16px;border-radius:50%;background:#fff;top:2px;left:2px;transition:.2s;box-shadow:0 1px 3px rgba(0,0,0,.15)}
.toggle.on::after{left:20px}
/* UPCOMING */
.upcoming-item{display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:1px solid var(--border)}
.upcoming-item:last-child{border-bottom:none}
.due-badge{padding:3px 9px;border-radius:99px;font-size:.7rem;font-weight:700;white-space:nowrap}
.due-soon{background:#fef9c3;color:#713f12}.due-today{background:var(--pink-l);color:#be123c}.due-ok{background:var(--green-l);color:#065f46}
/* EMPTY */
.empty{text-align:center;padding:36px 20px;color:var(--text-light);font-size:.875rem}
.empty-icon{font-size:2.5rem;margin-bottom:10px}
/* SCROLLBAR */
::-webkit-scrollbar{width:5px;height:5px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:var(--purple);border-radius:99px}
/* CHIP */
.chip{display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:99px;font-size:.72rem;font-weight:600;background:var(--purple-l);color:var(--text-mid)}
/* INCOME CARD */
.pay-card{background:linear-gradient(135deg,var(--purple-l),var(--blue-l));border:1.5px solid var(--border);border-radius:var(--radius);padding:20px;margin-bottom:16px}
.pay-amount{font-size:2rem;font-weight:800}
.pay-next{font-size:.82rem;color:var(--text-mid);margin-top:4px}
/* ── CALENDAR ── */
.cal-nav{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.cal-title{font-size:1rem;font-weight:700}
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:4px}
.cal-day-hdr{text-align:center;font-size:.7rem;font-weight:700;color:var(--text-light);padding:4px 0;text-transform:uppercase}
.cal-cell{min-height:72px;background:#faf8ff;border-radius:10px;border:1.5px solid var(--border);padding:5px 6px;position:relative;transition:.15s}
.cal-cell:hover{border-color:var(--purple);background:var(--purple-l)}
.cal-cell.today{border-color:var(--purple-d);background:var(--purple-l)}
.cal-cell.other-month{opacity:.4}
.cal-date{font-size:.75rem;font-weight:700;color:var(--text-mid);margin-bottom:3px}
.cal-bill-tag{font-size:.65rem;font-weight:600;padding:2px 5px;border-radius:5px;margin-bottom:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;cursor:default}
.cal-more{font-size:.62rem;color:var(--text-light);margin-top:2px}
/* DUE DATE TIMELINE */
.due-timeline-item{display:flex;align-items:center;gap:12px;padding:11px 0;border-bottom:1px solid var(--border)}
.due-timeline-item:last-child{border-bottom:none}
.due-day-circle{width:44px;height:44px;border-radius:50%;display:flex;flex-direction:column;align-items:center;justify-content:center;flex-shrink:0;font-size:.65rem;font-weight:700;color:#fff}
/* DOCUMENTS */
.doc-card{background:var(--card);border:1.5px solid var(--border);border-radius:var(--radius);padding:16px;box-shadow:var(--shadow);margin-bottom:10px;display:flex;align-items:flex-start;gap:14px}
.doc-icon{font-size:1.8rem;flex-shrink:0}
.doc-body{flex:1;min-width:0}
.doc-name{font-size:.9rem;font-weight:700;margin-bottom:4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.doc-meta{font-size:.75rem;color:var(--text-light);display:flex;gap:10px;flex-wrap:wrap;margin-bottom:6px}
.doc-notes{font-size:.78rem;color:var(--text-mid);background:var(--yellow-l);padding:6px 10px;border-radius:7px;margin-top:6px}
/* RESPONSIVE */
@media(max-width:900px){
  .sidebar{width:58px;padding:14px 6px}
  .sidebar-logo .logo-text,.nav-label,.sidebar-bottom{display:none}
  .main{margin-left:58px;padding:18px 14px 60px}
  .grid4,.grid3{grid-template-columns:1fr 1fr}.grid2{grid-template-columns:1fr}
}
@media(max-width:600px){
  .grid4,.grid3,.grid2{grid-template-columns:1fr}
  .main{padding:12px 8px 60px}
  .form-row{grid-template-columns:1fr}
}
</style>
</head>
<body>

<!-- SIDEBAR -->
<div class="sidebar">
  <div class="sidebar-logo"><span>🌸</span><span class="logo-text">My Budget</span></div>
  <nav>
    <div class="nav-item active" onclick="showPage('dashboard')"><span class="nav-icon">🏠</span><span class="nav-label">Dashboard</span></div>
    <div class="nav-item" onclick="showPage('income')"><span class="nav-icon">💵</span><span class="nav-label">Income</span></div>
    <div class="nav-item" onclick="showPage('bills')"><span class="nav-icon">🧾</span><span class="nav-label">Bills</span></div>
    <div class="nav-item" onclick="showPage('duedates')"><span class="nav-icon">📅</span><span class="nav-label">Due Dates</span></div>
    <div class="nav-item" onclick="showPage('loans')"><span class="nav-icon">🏦</span><span class="nav-label">Loans</span></div>
    <div class="nav-item" onclick="showPage('collections')"><span class="nav-icon">📋</span><span class="nav-label">Collections</span></div>
    <div class="nav-item" onclick="showPage('savings')"><span class="nav-icon">🌱</span><span class="nav-label">Savings</span></div>
    <div class="nav-item" onclick="showPage('documents')"><span class="nav-icon">📄</span><span class="nav-label">Documents</span></div>
  </nav>
  <div class="sidebar-bottom">
    <div class="net-label">Monthly Net</div>
    <div class="net-amount" id="sidebarNet">$0.00</div>
  </div>
</div>

<!-- MAIN -->
<div class="main">

  <!-- ══ DASHBOARD ══ -->
  <div class="page active" id="page-dashboard">
    <div class="page-header"><div class="page-title">Dashboard 🌸</div><div class="page-sub" id="dashDate"></div></div>
    <div class="grid4">
      <div class="card card-accent"><div class="card-title">Monthly Income</div><div class="card-value" id="dc-income">$0</div><div class="card-sub" id="dc-nextpay">—</div></div>
      <div class="card card-pink"><div class="card-title">Total Bills</div><div class="card-value" id="dc-bills">$0</div><div class="card-sub" id="dc-bills-paid">0 of 0 paid</div></div>
      <div class="card card-peach"><div class="card-title">Total Debt</div><div class="card-value" id="dc-debt">$0</div><div class="card-sub">Loans + Collections</div></div>
      <div class="card card-green"><div class="card-title">Savings Balance</div><div class="card-value" id="dc-savings">$0</div><div class="card-sub">Across all goals</div></div>
    </div>
    <div class="grid2">
      <div class="card"><div class="section-title">Paycheck Breakdown</div><div class="chart-wrap"><canvas id="chartBreakdown"></canvas></div></div>
      <div class="card"><div class="section-title">Monthly Overview</div><div class="chart-wrap"><canvas id="chartMonthly"></canvas></div></div>
    </div>
    <div class="card"><div class="section-title">Upcoming Payments <span id="upcomingCount" class="badge badge-purple"></span></div><div id="upcomingList"></div></div>
  </div>

  <!-- ══ INCOME ══ -->
  <div class="page" id="page-income">
    <div class="page-header"><div class="page-title">Income 💵</div><div class="page-sub">Track your paycheck and extra income</div></div>
    <div class="pay-card">
      <div style="display:flex;align-items:flex-start;justify-content:space-between">
        <div>
          <div style="font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:var(--text-mid);margin-bottom:4px">Paycheck</div>
          <div class="pay-amount" id="payAmountDisplay">$0.00</div>
          <div class="pay-next" id="payNextDisplay">Set your paycheck details →</div>
        </div>
        <button class="btn btn-ghost btn-sm" onclick="openModal('paycheck')">✏️ Edit</button>
      </div>
    </div>
    <div class="grid3" style="margin-bottom:20px">
      <div class="card card-accent"><div class="card-title">Monthly Gross</div><div class="card-value" id="inc-monthly">$0</div><div class="card-sub">2 paychecks/mo</div></div>
      <div class="card card-blue"><div class="card-title">Extra Income (MTD)</div><div class="card-value" id="inc-extra">$0</div><div class="card-sub">This month</div></div>
      <div class="card card-green"><div class="card-title">Total Available</div><div class="card-value" id="inc-total">$0</div><div class="card-sub">Paycheck + extras</div></div>
    </div>
    <div class="card">
      <div class="section-title">Extra Income<button class="btn btn-primary btn-sm" onclick="openModal('extraIncome')">+ Add</button></div>
      <div id="extraIncomeList"><div class="empty"><div class="empty-icon">💡</div>Add side income, bonuses, or other earnings</div></div>
    </div>
    <div class="card" style="margin-top:16px"><div class="section-title">Income Overview</div><div class="chart-wrap"><canvas id="chartIncome"></canvas></div></div>
  </div>

  <!-- ══ BILLS ══ -->
  <div class="page" id="page-bills">
    <div class="page-header"><div class="page-title">Bills 🧾</div><div class="page-sub">Manage your recurring bills and expenses</div></div>
    <div class="grid3" style="margin-bottom:16px">
      <div class="card card-pink"><div class="card-title">Total Monthly Bills</div><div class="card-value" id="bills-total">$0</div></div>
      <div class="card card-green"><div class="card-title">Paid This Month</div><div class="card-value" id="bills-paid-amt">$0</div></div>
      <div class="card card-peach"><div class="card-title">Remaining</div><div class="card-value" id="bills-remaining">$0</div></div>
    </div>
    <div class="card" style="margin-bottom:16px">
      <div style="display:flex;justify-content:space-between;margin-bottom:8px"><span style="font-size:.83rem;font-weight:600">Bills Paid Progress</span><span style="font-size:.83rem;color:var(--text-mid)" id="bills-pct-label">0%</span></div>
      <div class="progress-outer"><div class="progress-inner" id="bills-progress" style="width:0%;background:linear-gradient(90deg,var(--green),var(--mint))"></div></div>
    </div>
    <div class="grid2" style="margin-bottom:16px">
      <div class="card"><div class="section-title">By Category</div><div class="chart-wrap-sm"><canvas id="chartBillsCat"></canvas></div></div>
      <div class="card"><div class="section-title">Per Paycheck vs Monthly</div><div class="chart-wrap-sm"><canvas id="chartBillsFreq"></canvas></div></div>
    </div>
    <div class="tabs">
      <div class="tab active" onclick="setBillsTab('all',this)">All</div>
      <div class="tab" onclick="setBillsTab('biweekly',this)">Per Paycheck</div>
      <div class="tab" onclick="setBillsTab('monthly',this)">Monthly</div>
    </div>
    <div class="card">
      <div class="section-title">Bills<button class="btn btn-primary btn-sm" onclick="openModal('bill')">+ Add Bill</button></div>
      <div id="billsList"><div class="empty"><div class="empty-icon">🧾</div>No bills added yet</div></div>
    </div>
  </div>

  <!-- ══ DUE DATES ══ -->
  <div class="page" id="page-duedates">
    <div class="page-header"><div class="page-title">Due Dates 📅</div><div class="page-sub">Calendar view of all your bill due dates</div></div>
    <div class="grid3" style="margin-bottom:16px">
      <div class="card card-pink"><div class="card-title">Overdue / Due Today</div><div class="card-value" id="dd-overdue">0</div></div>
      <div class="card card-yellow"><div class="card-title">Due This Week</div><div class="card-value" id="dd-week">0</div></div>
      <div class="card card-green"><div class="card-title">Upcoming (30 days)</div><div class="card-value" id="dd-month">0</div></div>
    </div>
    <!-- Calendar -->
    <div class="card" style="margin-bottom:16px">
      <div class="cal-nav">
        <button class="btn btn-ghost btn-sm" onclick="calPrev()">← Prev</button>
