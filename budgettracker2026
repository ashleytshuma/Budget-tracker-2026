<script>
// ══════════════════════════════════════
// DATA
// ══════════════════════════════════════
const STORAGE_KEY='budgetTracker_v3';
let data={
  income:{amount:0,frequency:'biweekly',nextPayDate:'',extraIncome:[]},
  bills:[],
  loans:{short:[],long:[]},
  collections:[],
  savings:[],
  documents:[]
};

function load(){try{const s=localStorage.getItem(STORAGE_KEY);if(s)data=JSON.parse(s);if(!data.documents)data.documents=[];}catch(e){}}
function save(){localStorage.setItem(STORAGE_KEY,JSON.stringify(data));}

// ══════════════════════════════════════
// UTILS
// ══════════════════════════════════════
function fmt(n){return '$'+Number(n||0).toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2});}
function uid(){return Date.now().toString(36)+Math.random().toString(36).slice(2,6);}
function today(){return new Date().toISOString().split('T')[0];}
function daysBetween(a,b){return Math.round((new Date(b)-new Date(a))/(1000*60*60*24));}
function addMonths(dateStr,n){const d=new Date(dateStr);d.setMonth(d.getMonth()+n);return d.toISOString().split('T')[0];}
function fmtDate(s){if(!s)return'—';const d=new Date(s+'T00:00:00');return d.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});}
function monthlyIncome(){const a=Number(data.income.amount)||0;if(data.income.frequency==='biweekly')return a*2;if(data.income.frequency==='weekly')return a*4;return a;}
const COLORS=['#c4b5fd','#bae6fd','#86efac','#fdba74','#fca5a5','#fde68a','#99f6e4','#f9a8d4','#a5f3fc','#d9f99d'];
const BILL_CATS=['Housing','Utilities','Insurance','Subscriptions','Food','Transport','Phone','Healthcare','Other'];
const DOC_TYPES=['Statement','Notice','Agreement','Receipt','Tax Document','Payment Confirmation','Other'];
const DOC_ICONS={'Statement':'📊','Notice':'⚠️','Agreement':'📝','Receipt':'🧾','Tax Document':'📑','Payment Confirmation':'✅','Other':'📄'};

// ══════════════════════════════════════
// NAVIGATION
// ══════════════════════════════════════
function showPage(id){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  document.getElementById('page-'+id).classList.add('active');
  const map={dashboard:0,income:1,bills:2,duedates:3,loans:4,collections:5,savings:6,documents:7};
  document.querySelectorAll('.nav-item')[map[id]]?.classList.add('active');
  renderAll();
}

// ══════════════════════════════════════
// CHARTS
// ══════════════════════════════════════
let charts={};
function destroyChart(k){if(charts[k]){charts[k].destroy();delete charts[k];}}

function buildBreakdownChart(){
  destroyChart('breakdown');
  const ctx=document.getElementById('chartBreakdown').getContext('2d');
  const income=monthlyIncome();
  const bills=data.bills.reduce((s,b)=>s+Number(b.amount),0);
  const loans=[...data.loans.short,...data.loans.long].reduce((s,l)=>s+Number(l.minPayment),0);
  const colls=data.collections.reduce((s,c)=>s+Number(c.minPayment||0),0);
  const savings=data.savings.reduce((s,g)=>s+Number(g.monthlyContribution||0),0);
  const remaining=Math.max(0,income-bills-loans-colls-savings);
  charts['breakdown']=new Chart(ctx,{type:'doughnut',data:{labels:['Bills','Loan Payments','Collections','Savings','Remaining'],datasets:[{data:[bills,loans,colls,savings,remaining],backgroundColor:['#fca5a5','#fdba74','#fde68a','#86efac','#c4b5fd'],borderWidth:2,borderColor:'#fff',hoverOffset:6}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'right',labels:{font:{size:11},padding:12,boxWidth:12}}},cutout:'65%'}});
}
function buildMonthlyChart(){
  destroyChart('monthly');
  const ctx=document.getElementById('chartMonthly').getContext('2d');
  const income=monthlyIncome();
  const extra=data.income.extraIncome.filter(e=>{const d=new Date(e.date),n=new Date();return d.getMonth()===n.getMonth()&&d.getFullYear()===n.getFullYear();}).reduce((s,e)=>s+Number(e.amount),0);
  const bills=data.bills.reduce((s,b)=>s+Number(b.amount),0);
  const debt=[...data.loans.short,...data.loans.long].reduce((s,l)=>s+Number(l.minPayment),0)+data.collections.reduce((s,c)=>s+Number(c.minPayment||0),0);
  const sav=data.savings.reduce((s,g)=>s+Number(g.monthlyContribution||0),0);
  charts['monthly']=new Chart(ctx,{type:'bar',data:{labels:['Income','Bills','Debt Payments','Savings'],datasets:[{data:[income+extra,bills,debt,sav],backgroundColor:['#86efac','#fca5a5','#fdba74','#c4b5fd'],borderRadius:8,borderSkipped:false}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{y:{ticks:{callback:v=>'$'+v.toLocaleString()},grid:{color:'#f1eeff'}},x:{grid:{display:false}}}}});
}
function buildIncomeChart(){
  destroyChart('income');
  const ctx=document.getElementById('chartIncome').getContext('2d');
  const paycheck=monthlyIncome();
  const byMonth={};
  data.income.extraIncome.forEach(e=>{const k=e.date?.slice(0,7)||'';if(!k)return;byMonth[k]=(byMonth[k]||0)+Number(e.amount);});
  const months=Array.from({length:6},(_,i)=>{const d=new Date();d.setMonth(d.getMonth()-5+i);return d.toISOString().slice(0,7);});
  charts['income']=new Chart(ctx,{type:'bar',data:{labels:months.map(m=>{const[y,mo]=m.split('-');return new Date(y,mo-1).toLocaleDateString('en-US',{month:'short',year:'2-digit'})}),datasets:[{label:'Paycheck',data:months.map(()=>paycheck),backgroundColor:'#c4b5fd',borderRadius:6},{label:'Extra',data:months.map(m=>byMonth[m]||0),backgroundColor:'#86efac',borderRadius:6}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'top',labels:{font:{size:11}}}},scales:{x:{stacked:true,grid:{display:false}},y:{stacked:true,ticks:{callback:v=>'$'+v.toLocaleString()},grid:{color:'#f1eeff'}}}}});
}
function buildBillsCharts(){
  destroyChart('billsCat');destroyChart('billsFreq');
  const catCtx=document.getElementById('chartBillsCat').getContext('2d');
  const freqCtx=document.getElementById('chartBillsFreq').getContext('2d');
  const cats={};data.bills.forEach(b=>{cats[b.category||'Other']=(cats[b.category||'Other']||0)+Number(b.amount);});
  charts['billsCat']=new Chart(catCtx,{type:'doughnut',data:{labels:Object.keys(cats),datasets:[{data:Object.values(cats),backgroundColor:COLORS,borderWidth:2,borderColor:'#fff'}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'right',labels:{font:{size:10},padding:8,boxWidth:10}}},cutout:'60%'}});
  const bw=data.bills.filter(b=>b.frequency==='biweekly').reduce((s,b)=>s+Number(b.amount),0);
  const mo=data.bills.filter(b=>b.frequency==='monthly').reduce((s,b)=>s+Number(b.amount),0);
  charts['billsFreq']=new Chart(freqCtx,{type:'bar',data:{labels:['Per Paycheck','Monthly'],datasets:[{data:[bw,mo],backgroundColor:['#bae6fd','#fca5a5'],borderRadius:8,borderSkipped:false}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{y:{ticks:{callback:v=>'$'+v.toLocaleString()},grid:{color:'#f1eeff'}},x:{grid:{display:false}}}}});
}
function buildDebtChart(){
  destroyChart('debt');
  const ctx=document.getElementById('chartDebt').getContext('2d');
  const all=[...data.loans.short,...data.loans.long,...data.collections.map(c=>({...c,name:c.creditor,balance:c.currentAmount}))];
  if(!all.length)return;
  charts['debt']=new Chart(ctx,{type:'bar',data:{labels:all.map(l=>l.name),datasets:[{label:'Original',data:all.map(l=>Number(l.originalAmount||0)),backgroundColor:'rgba(196,181,253,.3)',borderRadius:6},{label:'Balance',data:all.map(l=>Number(l.balance||0)),backgroundColor:COLORS.slice(0,all.length),borderRadius:6}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'top',labels:{font:{size:11}}}},scales:{y:{ticks:{callback:v=>'$'+v.toLocaleString()},grid:{color:'#f1eeff'}},x:{grid:{display:false}}}}});
}
function buildSavingsChart(){
  destroyChart('savings');
  if(!data.savings.length)return;
  const ctx=document.getElementById('chartSavings').getContext('2d');
  charts['savings']=new Chart(ctx,{type:'bar',data:{labels:data.savings.map(g=>g.name),datasets:[{label:'Saved',data:data.savings.map(g=>Number(g.currentAmount||0)),backgroundColor:data.savings.map((_,i)=>COLORS[i%COLORS.length]),borderRadius:8,borderSkipped:false},{label:'Target',data:data.savings.map(g=>Number(g.targetAmount||0)),backgroundColor:'rgba(196,181,253,.25)',borderRadius:8,borderSkipped:false}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'top',labels:{font:{size:11}}}},scales:{y:{ticks:{callback:v=>'$'+v.toLocaleString()},grid:{color:'#f1eeff'}},x:{grid:{display:false}}}}});
}

// ══════════════════════════════════════
// CALENDAR
// ══════════════════════════════════════
let calYear=new Date().getFullYear();
let calMonth=new Date().getMonth();

function calPrev(){calMonth--;if(calMonth<0){calMonth=11;calYear--;}renderDueDates();}
function calNext(){calMonth++;if(calMonth>11){calMonth=0;calYear++;}renderDueDates();}

function buildCalendar(){
  const monthNames=['January','February','March','April','May','June','July','August','September','October','November','December'];
  document.getElementById('calTitle').textContent=monthNames[calMonth]+' '+calYear;
  const grid=document.getElementById('calGrid');
  const dayHeaders=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  const todayStr=today();
  const now=new Date();
  // Cat colors
  const catColors={Housing:'#fca5a5',Utilities:'#bae6fd',Insurance:'#c4b5fd',Subscriptions:'#fdba74',Food:'#86efac',Transport:'#fde68a',Phone:'#99f6e4',Healthcare:'#f9a8d4',Other:'#d1d5db'};

  let html=dayHeaders.map(d=>`<div class="cal-day-hdr">${d}</div>`).join('');

  const firstDay=new Date(calYear,calMonth,1).getDay();
  const daysInMonth=new Date(calYear,calMonth+1,0).getDate();
  const daysInPrev=new Date(calYear,calMonth,0).getDate();

  // Build bills-by-day map
  const billsByDay={};
  data.bills.forEach(b=>{
    const d=parseInt(b.dueDay)||1;
    if(!billsByDay[d])billsByDay[d]=[];
    billsByDay[d].push(b);
  });

  // Prev month filler
  for(let i=0;i<firstDay;i++){
    const d=daysInPrev-firstDay+i+1;
    html+=`<div class="cal-cell other-month"><div class="cal-date">${d}</div></div>`;
  }

  for(let d=1;d<=daysInMonth;d++){
    const dateStr=`${calYear}-${String(calMonth+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const isToday=dateStr===todayStr;
    const bills=billsByDay[d]||[];
    const billsHTML=bills.slice(0,2).map(b=>`<div class="cal-bill-tag" style="background:${catColors[b.category]||'#e5e7eb'};color:#3d3466" title="${esc(b.name)} — ${fmt(b.amount)}">${esc(b.name.length>12?b.name.slice(0,11)+'…':b.name)}</div>`).join('');
    const more=bills.length>2?`<div class="cal-more">+${bills.length-2} more</div>`:'';
    html+=`<div class="cal-cell${isToday?' today':''}" title="${bills.map(b=>b.name+': '+fmt(b.amount)).join(', ')||''}">
      <div class="cal-date" style="${isToday?'color:var(--purple-d);font-weight:800':''}">${d}</div>
      ${billsHTML}${more}
    </div>`;
  }
  // Next month filler
  const total=firstDay+daysInMonth;
  const remaining=total%7===0?0:7-(total%7);
  for(let i=1;i<=remaining;i++){html+=`<div class="cal-cell other-month"><div class="cal-date">${i}</div></div>`;}

  grid.innerHTML=html;

  // Legend
  const usedCats=[...new Set(data.bills.map(b=>b.category||'Other'))];
  document.getElementById('calLegend').innerHTML=usedCats.map(c=>`<div style="display:flex;align-items:center;gap:5px;font-size:.72rem;font-weight:600"><div style="width:10px;height:10px;border-radius:3px;background:${catColors[c]||'#e5e7eb'}"></div>${c}</div>`).join('');
}

// ══════════════════════════════════════
// RENDER
// ══════════════════════════════════════
let billsTabFilter='all';
let loansTab='short';
let docsTabFilter='all';

function renderAll(){
  renderSidebar();
  const active=document.querySelector('.page.active')?.id?.replace('page-','');
  if(active==='dashboard')renderDashboard();
  if(active==='income')renderIncome();
  if(active==='bills')renderBills();
  if(active==='duedates')renderDueDates();
  if(active==='loans')renderLoans();
  if(active==='collections')renderCollections();
  if(active==='savings')renderSavings();
  if(active==='documents')renderDocuments();
}

function renderSidebar(){
  const income=monthlyIncome()+data.income.extraIncome.filter(e=>{const d=new Date(e.date),n=new Date();return d.getMonth()===n.getMonth()&&d.getFullYear()===n.getFullYear();}).reduce((s,e)=>s+Number(e.amount),0);
  const bills=data.bills.reduce((s,b)=>s+Number(b.amount),0);
  const debt=[...data.loans.short,...data.loans.long].reduce((s,l)=>s+Number(l.minPayment||0),0)+data.collections.reduce((s,c)=>s+Number(c.minPayment||0),0);
  const sav=data.savings.reduce((s,g)=>s+Number(g.monthlyContribution||0),0);
  const net=income-bills-debt-sav;
  const el=document.getElementById('sidebarNet');
  el.textContent=fmt(net);el.className='net-amount '+(net>=0?'positive':'negative');
}

function renderDashboard(){
  document.getElementById('dashDate').textContent=new Date().toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric',year:'numeric'});
  document.getElementById('dc-income').textContent=fmt(monthlyIncome());
  document.getElementById('dc-nextpay').textContent=data.income.nextPayDate?'Next pay: '+fmtDate(data.income.nextPayDate):'Set paycheck info';
  document.getElementById('dc-bills').textContent=fmt(data.bills.reduce((s,b)=>s+Number(b.amount),0));
  document.getElementById('dc-bills-paid').textContent=`${data.bills.filter(b=>b.paid).length} of ${data.bills.length} paid`;
  const debt=[...data.loans.short,...data.loans.long].reduce((s,l)=>s+Number(l.balance||0),0)+data.collections.reduce((s,c)=>s+Number(c.currentAmount||0),0);
  document.getElementById('dc-debt').textContent=fmt(debt);
  document.getElementById('dc-savings').textContent=fmt(data.savings.reduce((s,g)=>s+Number(g.currentAmount||0),0));
  renderUpcoming();buildBreakdownChart();buildMonthlyChart();
}

function renderUpcoming(){
  const t=today();
  const upcoming=data.bills.filter(b=>!b.paid).map(b=>{
    const dd=parseInt(b.dueDay)||1,now=new Date();
    let due=new Date(now.getFullYear(),now.getMonth(),dd);
    if(due<now)due=new Date(now.getFullYear(),now.getMonth()+1,dd);
    return{...b,dueDate:due.toISOString().split('T')[0],daysUntil:daysBetween(t,due.toISOString().split('T')[0])};
  }).sort((a,b)=>a.daysUntil-b.daysUntil).slice(0,8);
  const el=document.getElementById('upcomingList');
  document.getElementById('upcomingCount').textContent=upcoming.length;
  if(!upcoming.length){el.innerHTML='<div class="empty"><div class="empty-icon">✅</div>All bills paid!</div>';return;}
  el.innerHTML=upcoming.map(b=>{
    let cls='due-ok',lbl='On time';
    if(b.daysUntil<=0){cls='due-today';lbl='Due Today!';}
    else if(b.daysUntil<=3){cls='due-soon';lbl=`Due in ${b.daysUntil}d`;}
    else lbl=`Due ${fmtDate(b.dueDate)}`;
    return`<div class="upcoming-item"><div style="font-size:1.1rem">${getCatIcon(b.category)}</div><div style="flex:1"><div style="font-size:.875rem;font-weight:600">${esc(b.name)}</div><div class="item-meta">${b.category||'Other'}</div></div><div style="font-weight:700;margin-right:10px">${fmt(b.amount)}</div><span class="due-badge ${cls}">${lbl}</span></div>`;
  }).join('');
}

