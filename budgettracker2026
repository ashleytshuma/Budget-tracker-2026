    <div class="progress-outer"><div class="progress-inner" style="width:${pct}%;background:${color}"></div></div>
    ${eta?`<div style="font-size:.75rem;color:var(--text-light);margin-top:8px">🗓 Projected payoff: ${fmtDate(eta)} (${monthsLeft} months)</div>`:''}
    ${g.notes?`<div style="font-size:.75rem;color:var(--text-light);margin-top:6px">${esc(g.notes)}</div>`:''}
    <div style="margin-top:10px"><button class="btn btn-green btn-sm" onclick="depositGoal('${g.id}')">+ Deposit</button></div>
  </div>`;
}

// ── DOCUMENTS PAGE ──
function renderDocuments(){
  const docs=docsTabFilter==='all'?data.documents:data.documents.filter(d=>d.linkedType===docsTabFilter);
  document.getElementById('docs-count').textContent=data.documents.length;
  document.getElementById('docs-statements').textContent=data.documents.filter(d=>d.type==='Statement').length;
  document.getElementById('docs-notices').textContent=data.documents.filter(d=>d.type==='Notice').length;
  document.getElementById('docs-agreements').textContent=data.documents.filter(d=>d.type==='Agreement').length;
  const el=document.getElementById('documentsList');
  if(!docs.length){el.innerHTML='<div class="empty"><div class="empty-icon">📂</div>No documents in this view</div>';return;}
  const sorted=[...docs].sort((a,b)=>b.date?.localeCompare(a.date||'')||0);
  el.innerHTML=sorted.map(d=>{
    const linked=getLinkedName(d.linkedId,d.linkedType);
    return`<div class="doc-card">
      <div class="doc-icon">${DOC_ICONS[d.type]||'📄'}</div>
      <div class="doc-body">
        <div class="doc-name">${esc(d.name)}</div>
        <div class="doc-meta">
          <span class="badge badge-purple">${d.type||'Other'}</span>
          <span class="badge ${d.linkedType==='bill'?'badge-pink':d.linkedType==='loan'?'badge-peach':'badge-blue'}">${d.linkedType||'—'}</span>
          ${linked?`<span>🔗 ${esc(linked)}</span>`:''}
          <span>📅 ${fmtDate(d.date)}</span>
          ${d.period?`<span>Period: ${esc(d.period)}</span>`:''}
          ${d.amount?`<span style="font-weight:700;color:#059669">${fmt(d.amount)}</span>`:''}
        </div>
        ${d.notes?`<div class="doc-notes">📝 ${esc(d.notes)}</div>`:''}
        ${d.fileName?`<div style="font-size:.72rem;color:var(--text-light);margin-top:5px">📎 ${esc(d.fileName)}</div>`:''}
      </div>
      <div style="display:flex;flex-direction:column;gap:6px;flex-shrink:0">
        <button class="btn btn-ghost btn-sm" onclick="editDoc('${d.id}')">✏️</button>
        <button class="btn btn-danger btn-sm" onclick="deleteDoc('${d.id}')">✕</button>
      </div>
    </div>`;
  }).join('');
}

function getLinkedName(id,type){
  if(type==='bill')return data.bills.find(b=>b.id===id)?.name||'';
  if(type==='loan')return[...data.loans.short,...data.loans.long].find(l=>l.id===id)?.name||'';
  if(type==='collection')return data.collections.find(c=>c.id===id)?.creditor||'';
  return'';
}

function setDocsTab(tab,el){docsTabFilter=tab;document.querySelectorAll('#page-documents .tab').forEach(t=>t.classList.remove('active'));el.classList.add('active');renderDocuments();}

// ══════════════════════════════════════
// MODALS
// ══════════════════════════════════════
let currentModal='';
let editingId='';
let loanTypeCtx='short';
let quickDocCtx={type:'',id:'',name:''};

function openModal(type,ctx){
  currentModal=type;loanTypeCtx=ctx||'short';
  const titles={paycheck:'Paycheck Details',bill:'Add Bill',extraIncome:'Add Extra Income',loan:'Add Loan',collection:'Add Collection Account',goal:'Add Savings Goal',document:'Add Document'};
  document.getElementById('modalTitle').textContent=editingId?'Edit':titles[type]||'Add';
  document.getElementById('modalBody').innerHTML=getModalBody(type);
  document.getElementById('modalOverlay').classList.add('open');
}
function closeModal(){document.getElementById('modalOverlay').classList.remove('open');editingId='';setTimeout(()=>document.getElementById('modalBody').innerHTML='',200);}
function closeModalOutside(e){if(e.target===document.getElementById('modalOverlay'))closeModal();}

function buildLinkedOptions(selectedId=''){
  let opts='<option value="">— None —</option>';
  if(data.bills.length){opts+='<optgroup label="Bills">';data.bills.forEach(b=>{opts+=`<option value="${b.id}" data-type="bill" ${b.id===selectedId?'selected':''}>${esc(b.name)}</option>`;});opts+='</optgroup>';}
  const allLoans=[...data.loans.short,...data.loans.long];
  if(allLoans.length){opts+='<optgroup label="Loans">';allLoans.forEach(l=>{opts+=`<option value="${l.id}" data-type="loan" ${l.id===selectedId?'selected':''}>${esc(l.name)}</option>`;});opts+='</optgroup>';}
  if(data.collections.length){opts+='<optgroup label="Collections">';data.collections.forEach(c=>{opts+=`<option value="${c.id}" data-type="collection" ${c.id===selectedId?'selected':''}>${esc(c.creditor)}</option>`;});opts+='</optgroup>';}
  return opts;
}

function getModalBody(type){
  if(type==='paycheck'){
    return`<div class="form-row">
      <div class="form-group"><label>Net Paycheck Amount</label><input id="f-payAmt" type="number" placeholder="0.00" value="${data.income.amount||''}"></div>
      <div class="form-group"><label>Pay Frequency</label><select id="f-payFreq">
        <option value="biweekly" ${data.income.frequency==='biweekly'?'selected':''}>Bi-Weekly</option>
        <option value="weekly" ${data.income.frequency==='weekly'?'selected':''}>Weekly</option>
        <option value="monthly" ${data.income.frequency==='monthly'?'selected':''}>Monthly</option>
      </select></div>
    </div>
    <div class="form-row-1"><div class="form-group"><label>Next Pay Date</label><input id="f-payDate" type="date" value="${data.income.nextPayDate||''}"></div></div>
    <div class="modal-footer"><button class="btn btn-ghost" onclick="closeModal()">Cancel</button><button class="btn btn-primary" onclick="savePaycheck()">Save</button></div>`;
  }
  if(type==='bill'){
    const b=editingId?data.bills.find(x=>x.id===editingId):null;
    return`<div class="form-row">
      <div class="form-group"><label>Bill Name</label><input id="f-bName" type="text" placeholder="e.g. Netflix" value="${b?esc(b.name):''}"></div>
      <div class="form-group"><label>Amount</label><input id="f-bAmt" type="number" placeholder="0.00" value="${b?b.amount:''}"></div>
    </div>
    <div class="form-row">
      <div class="form-group"><label>Category</label><select id="f-bCat">${BILL_CATS.map(c=>`<option ${b&&b.category===c?'selected':''}>${c}</option>`).join('')}</select></div>
      <div class="form-group"><label>Frequency</label><select id="f-bFreq"><option value="monthly" ${!b||b.frequency==='monthly'?'selected':''}>Monthly</option><option value="biweekly" ${b&&b.frequency==='biweekly'?'selected':''}>Per Paycheck</option></select></div>
    </div>
    <div class="form-row-1"><div class="form-group"><label>Due Day of Month (1–31)</label><input id="f-bDue" type="number" min="1" max="31" placeholder="e.g. 15" value="${b?b.dueDay:''}"></div></div>
    <div class="modal-footer"><button class="btn btn-ghost" onclick="closeModal()">Cancel</button><button class="btn btn-primary" onclick="saveBill()">Save Bill</button></div>`;
  }
  if(type==='extraIncome'){
    return`<div class="form-row">
      <div class="form-group"><label>Description</label><input id="f-eDesc" type="text" placeholder="e.g. Freelance, Bonus"></div>
      <div class="form-group"><label>Amount</label><input id="f-eAmt" type="number" placeholder="0.00"></div>
    </div>
    <div class="form-row-1"><div class="form-group"><label>Date</label><input id="f-eDate" type="date" value="${today()}"></div></div>
    <div class="modal-footer"><button class="btn btn-ghost" onclick="closeModal()">Cancel</button><button class="btn btn-primary" onclick="saveExtraIncome()">Add</button></div>`;
  }
  if(type==='loan'){
    const l=editingId?findLoan(editingId):null;
    return`<div class="form-row">
      <div class="form-group"><label>Loan Name</label><input id="f-lName" type="text" placeholder="e.g. Car Loan" value="${l?esc(l.name):''}"></div>
      <div class="form-group"><label>Lender / Bank</label><input id="f-lLender" type="text" placeholder="e.g. Wells Fargo" value="${l?esc(l.lender||''):''}"></div>
    </div>
    <div class="form-row">
      <div class="form-group"><label>Original Amount</label><input id="f-lOrig" type="number" placeholder="0.00" value="${l?l.originalAmount:''}"></div>
      <div class="form-group"><label>Current Balance</label><input id="f-lBal" type="number" placeholder="0.00" value="${l?l.balance:''}"></div>
    </div>
    <div class="form-row">
      <div class="form-group"><label>Interest Rate (APR %)</label><input id="f-lRate" type="number" placeholder="e.g. 5.99" step="0.01" value="${l?l.interestRate:''}"></div>
      <div class="form-group"><label>Min. Monthly Payment</label><input id="f-lMin" type="number" placeholder="0.00" value="${l?l.minPayment:''}"></div>
    </div>
    <div class="form-row-1"><div class="form-group"><label>Notes</label><input id="f-lNotes" type="text" placeholder="Optional" value="${l?esc(l.notes||''):''}"></div></div>
    <div class="modal-footer"><button class="btn btn-ghost" onclick="closeModal()">Cancel</button><button class="btn btn-primary" onclick="saveLoanModal()">Save Loan</button></div>`;
  }
  if(type==='collection'){
    const c=editingId?data.collections.find(x=>x.id===editingId):null;
    return`<div class="form-row">
      <div class="form-group"><label>Creditor / Agency</label><input id="f-cCred" type="text" placeholder="e.g. Midland Credit" value="${c?esc(c.creditor):''}"></div>
      <div class="form-group"><label>Account Reference</label><input id="f-cRef" type="text" placeholder="Last 4 / ref #" value="${c?esc(c.accountRef||''):''}"></div>
    </div>
    <div class="form-row">
      <div class="form-group"><label>Original Amount</label><input id="f-cOrig" type="number" placeholder="0.00" value="${c?c.originalAmount:''}"></div>
      <div class="form-group"><label>Current Amount Owed</label><input id="f-cCurr" type="number" placeholder="0.00" value="${c?c.currentAmount:''}"></div>
    </div>
    <div class="form-row">
      <div class="form-group"><label>Settlement Offer ($)</label><input id="f-cSettle" type="number" placeholder="0.00" value="${c?c.settlementAmount||'':''}"></div>
      <div class="form-group"><label>Min. Monthly Payment</label><input id="f-cMin" type="number" placeholder="0.00" value="${c?c.minPayment||'':''}"></div>
    </div>
    <div class="form-row">
      <div class="form-group"><label>Status</label><select id="f-cStatus"><option value="active" ${!c||c.status==='active'?'selected':''}>Active</option><option value="disputed" ${c&&c.status==='disputed'?'selected':''}>Disputed</option><option value="settled" ${c&&c.status==='settled'?'selected':''}>Settled</option><option value="paid" ${c&&c.status==='paid'?'selected':''}>Paid</option></select></div>
      <div></div>
    </div>
    <div class="form-row-1"><div class="form-group"><label>Notes / Strategy</label><textarea id="f-cNotes" placeholder="Notes, disputes, negotiation strategy...">${c?esc(c.notes||''):''}</textarea></div></div>
    <div class="modal-footer"><button class="btn btn-ghost" onclick="closeModal()">Cancel</button><button class="btn btn-primary" onclick="saveCollection()">Save Account</button></div>`;
  }
  if(type==='goal'){
    const g=editingId?data.savings.find(x=>x.id===editingId):null;
    return`<div class="form-row">
      <div class="form-group"><label>Goal Name</label><input id="f-gName" type="text" placeholder="e.g. Emergency Fund" value="${g?esc(g.name):''}"></div>
      <div class="form-group"><label>Target Amount</label><input id="f-gTarget" type="number" placeholder="0.00" value="${g?g.targetAmount:''}"></div>
    </div>
    <div class="form-row">
      <div class="form-group"><label>Current Amount Saved</label><input id="f-gCurr" type="number" placeholder="0.00" value="${g?g.currentAmount:''}"></div>
      <div class="form-group"><label>Monthly Contribution</label><input id="f-gMonthly" type="number" placeholder="0.00" value="${g?g.monthlyContribution:''}"></div>
    </div>
    <div class="form-row-1"><div class="form-group"><label>Target Date (optional)</label><input id="f-gDate" type="date" value="${g?g.targetDate||'':''}"></div></div>
    <div class="form-row-1"><div class="form-group"><label>Notes</label><input id="f-gNotes" type="text" placeholder="Optional" value="${g?esc(g.notes||''):''}"></div></div>
    <div class="modal-footer"><button class="btn btn-ghost" onclick="closeModal()">Cancel</button><button class="btn btn-primary" onclick="saveGoal()">Save Goal</button></div>`;
  }
  if(type==='document'){
    const d=editingId?data.documents.find(x=>x.id===editingId):null;
    const preLinkedId=d?d.linkedId:(quickDocCtx.id||'');
    const preLinkedType=d?d.linkedType:(quickDocCtx.type||'');
    return`<div class="form-row">
      <div class="form-group"><label>Document Name</label><input id="f-dName" type="text" placeholder="e.g. March 2026 Statement" value="${d?esc(d.name):''}"></div>
      <div class="form-group"><label>Document Type</label><select id="f-dType">${DOC_TYPES.map(t=>`<option ${d&&d.type===t?'selected':''}>${t}</option>`).join('')}</select></div>
    </div>
    <div class="form-row">
      <div class="form-group"><label>Date Received</label><input id="f-dDate" type="date" value="${d?d.date||today():today()}"></div>
      <div class="form-group"><label>Statement Period (optional)</label><input id="f-dPeriod" type="text" placeholder="e.g. Mar 1–31, 2026" value="${d?esc(d.period||''):''}"></div>
    </div>
    <div class="form-row">
      <div class="form-group"><label>Linked To</label>
        <select id="f-dLinked" onchange="setLinkedType(this)">${buildLinkedOptions(preLinkedId)}</select>
      </div>
      <div class="form-group"><label>Amount on Statement (optional)</label><input id="f-dAmt" type="number" placeholder="0.00" value="${d?d.amount||'':''}"></div>
    </div>
    <div class="form-row-1"><div class="form-group"><label>File Name / Reference (optional)</label><input id="f-dFile" type="text" placeholder="e.g. march-statement.pdf or path" value="${d?esc(d.fileName||''):''}"></div></div>
    <div class="form-row-1"><div class="form-group"><label>Notes</label><textarea id="f-dNotes" placeholder="Key details from this document...">${d?esc(d.notes||''):''}</textarea></div></div>
    <input type="hidden" id="f-dLinkedType" value="${preLinkedType}">
    <div class="modal-footer"><button class="btn btn-ghost" onclick="closeModal()">Cancel</button><button class="btn btn-primary" onclick="saveDocument()">Save Document</button></div>`;
  }
  if(type==='deposit'){
    return`<div class="form-row-1"><div class="form-group"><label>Deposit Amount</label><input id="f-depAmt" type="number" placeholder="0.00" min="0" step="0.01"></div></div>
    <div class="modal-footer"><button class="btn btn-ghost" onclick="closeModal()">Cancel</button><button class="btn btn-primary" onclick="saveDeposit()">Add</button></div>`;
  }
  return'';
}

function setLinkedType(sel){
  const opt=sel.options[sel.selectedIndex];
  const type=opt.getAttribute('data-type')||'';
  document.getElementById('f-dLinkedType').value=type;
}

function quickAddDoc(linkedType,linkedId,linkedName){
  quickDocCtx={type:linkedType,id:linkedId,name:linkedName};
  editingId='';
  currentModal='document';
  document.getElementById('modalTitle').textContent='Add Document';
  document.getElementById('modalBody').innerHTML=getModalBody('document');
  document.getElementById('modalOverlay').classList.add('open');
}

// ══════════════════════════════════════
// SAVE HANDLERS
// ══════════════════════════════════════
function savePaycheck(){
  data.income.amount=parseFloat(document.getElementById('f-payAmt')?.value)||0;
  data.income.frequency=document.getElementById('f-payFreq')?.value||'biweekly';
  data.income.nextPayDate=document.getElementById('f-payDate')?.value||'';
  save();closeModal();renderAll();
}
function saveBill(){
  const name=document.getElementById('f-bName')?.value?.trim();
  if(!name)return alert('Enter a bill name');
  const bill={id:editingId||uid(),name,amount:parseFloat(document.getElementById('f-bAmt')?.value)||0,category:document.getElementById('f-bCat')?.value||'Other',frequency:document.getElementById('f-bFreq')?.value||'monthly',dueDay:parseInt(document.getElementById('f-bDue')?.value)||1,paid:false};
  if(editingId){const i=data.bills.findIndex(b=>b.id===editingId);if(i>=0){bill.paid=data.bills[i].paid;data.bills[i]=bill;}}else data.bills.push(bill);
  editingId='';save();closeModal();renderAll();
}
function saveExtraIncome(){
  const desc=document.getElementById('f-eDesc')?.value?.trim();
  if(!desc)return alert('Enter a description');
  data.income.extraIncome.push({id:uid(),description:desc,amount:parseFloat(document.getElementById('f-eAmt')?.value)||0,date:document.getElementById('f-eDate')?.value||today()});
  save();closeModal();renderAll();
}
function saveLoanModal(){
  const name=document.getElementById('f-lName')?.value?.trim();
  if(!name)return alert('Enter a loan name');
  const loan={id:editingId||uid(),name,lender:document.getElementById('f-lLender')?.value||'',originalAmount:parseFloat(document.getElementById('f-lOrig')?.value)||0,balance:parseFloat(document.getElementById('f-lBal')?.value)||0,interestRate:parseFloat(document.getElementById('f-lRate')?.value)||0,minPayment:parseFloat(document.getElementById('f-lMin')?.value)||0,notes:document.getElementById('f-lNotes')?.value||''};
  const arr=data.loans[loanTypeCtx];
  if(editingId){const i=arr.findIndex(l=>l.id===editingId);if(i>=0){loan.plan=arr[i].plan;arr[i]=loan;}}else arr.push(loan);
  editingId='';save();closeModal();renderAll();
}
function saveCollection(){
  const cred=document.getElementById('f-cCred')?.value?.trim();
  if(!cred)return alert('Enter creditor name');
  const coll={id:editingId||uid(),creditor:cred,accountRef:document.getElementById('f-cRef')?.value||'',originalAmount:parseFloat(document.getElementById('f-cOrig')?.value)||0,currentAmount:parseFloat(document.getElementById('f-cCurr')?.value)||0,settlementAmount:parseFloat(document.getElementById('f-cSettle')?.value)||0,minPayment:parseFloat(document.getElementById('f-cMin')?.value)||0,status:document.getElementById('f-cStatus')?.value||'active',notes:document.getElementById('f-cNotes')?.value||''};
  if(editingId){const i=data.collections.findIndex(c=>c.id===editingId);if(i>=0){coll.plan=data.collections[i].plan;data.collections[i]=coll;}}else data.collections.push(coll);
  editingId='';save();closeModal();renderAll();
}
function saveGoal(){
  const name=document.getElementById('f-gName')?.value?.trim();
  if(!name)return alert('Enter a goal name');
  const goal={id:editingId||uid(),name,targetAmount:parseFloat(document.getElementById('f-gTarget')?.value)||0,currentAmount:parseFloat(document.getElementById('f-gCurr')?.value)||0,monthlyContribution:parseFloat(document.getElementById('f-gMonthly')?.value)||0,targetDate:document.getElementById('f-gDate')?.value||'',notes:document.getElementById('f-gNotes')?.value||''};
  if(editingId){const i=data.savings.findIndex(g=>g.id===editingId);if(i>=0)data.savings[i]=goal;}else data.savings.push(goal);
  editingId='';save();closeModal();renderAll();
}
function saveDocument(){
  const name=document.getElementById('f-dName')?.value?.trim();
  if(!name)return alert('Enter a document name');
  const sel=document.getElementById('f-dLinked');
  const linkedId=sel?.value||'';
  const linkedType=document.getElementById('f-dLinkedType')?.value||sel?.options[sel.selectedIndex]?.getAttribute('data-type')||'';
  const doc={
    id:editingId||uid(),name,
    type:document.getElementById('f-dType')?.value||'Other',
    date:document.getElementById('f-dDate')?.value||today(),
    period:document.getElementById('f-dPeriod')?.value||'',
    linkedId,linkedType,
    amount:parseFloat(document.getElementById('f-dAmt')?.value)||0,
    fileName:document.getElementById('f-dFile')?.value||'',
    notes:document.getElementById('f-dNotes')?.value||''
  };
  if(editingId){const i=data.documents.findIndex(d=>d.id===editingId);if(i>=0)data.documents[i]=doc;}else data.documents.push(doc);
  editingId='';quickDocCtx={type:'',id:'',name:''};save();closeModal();renderAll();
}

let depositGoalId='';
function depositGoal(id){depositGoalId=id;document.getElementById('modalTitle').textContent='Add to Savings';document.getElementById('modalBody').innerHTML=getModalBody('deposit');document.getElementById('modalOverlay').classList.add('open');currentModal='deposit';}
function saveDeposit(){const amt=parseFloat(document.getElementById('f-depAmt')?.value)||0;const g=data.savings.find(x=>x.id===depositGoalId);if(g){g.currentAmount=(Number(g.currentAmount)||0)+amt;save();}closeModal();renderAll();}

// ══════════════════════════════════════
// EDIT / DELETE
// ══════════════════════════════════════
function editBill(id){editingId=id;openModal('bill');}
function deleteBill(id){if(confirm('Delete this bill?')){data.bills=data.bills.filter(b=>b.id!==id);save();renderAll();}}
function toggleBillPaid(id){const b=data.bills.find(x=>x.id===id);if(b){b.paid=!b.paid;save();renderAll();}}
function deleteExtraIncome(id){data.income.extraIncome=data.income.extraIncome.filter(e=>e.id!==id);save();renderAll();}
function editLoan(id,type){editingId=id;loanTypeCtx=type;openModal('loan',type);}
function deleteLoan(id,type){if(confirm('Delete this loan?')){data.loans[type]=data.loans[type].filter(l=>l.id!==id);save();renderAll();}}
function editCollection(id){editingId=id;openModal('collection');}
function deleteCollection(id){if(confirm('Delete this account?')){data.collections=data.collections.filter(c=>c.id!==id);save();renderAll();}}
function editGoal(id){editingId=id;openModal('goal');}
function deleteGoal(id){if(confirm('Delete this goal?')){data.savings=data.savings.filter(g=>g.id!==id);save();renderAll();}}
function editDoc(id){editingId=id;openModal('document');}
function deleteDoc(id){if(confirm('Delete this document?')){data.documents=data.documents.filter(d=>d.id!==id);save();renderAll();}}

function setBillsTab(tab,el){billsTabFilter=tab;document.querySelectorAll('#page-bills .tab').forEach(t=>t.classList.remove('active'));el.classList.add('active');renderBills();}
function setLoanTab(tab,el){loansTab=tab;document.querySelectorAll('#page-loans .tab').forEach(t=>t.classList.remove('active'));el.classList.add('active');document.getElementById('loansShortPanel').style.display=tab==='short'?'':'none';document.getElementById('loansLongPanel').style.display=tab==='long'?'':'none';}

function esc(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}

// INIT
load();renderAll();
</script>
</body>
